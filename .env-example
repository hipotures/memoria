MEMORIA_DATABASE_URL=sqlite:///./data/memoria.db
MEMORIA_SEED=42

MEMORIA_OCR_ENGINE=paddleocr
MEMORIA_OCR_LANGUAGE_HINT=
MEMORIA_PADDLE_LANG=en
MEMORIA_PADDLE_USE_ANGLE_CLS=true
MEMORIA_PADDLE_USE_GPU=false

MEMORIA_VISION_ENGINE=ollama
MEMORIA_VISION_LANGUAGE_HINT=pl,en
MEMORIA_VISION_API_BASE_URL=http://127.0.0.1:11434
MEMORIA_VISION_MODEL=qwen3.5:9b
MEMORIA_VISION_TEMPERATURE=0.1
MEMORIA_VISION_TIMEOUT_SECONDS=120.0
MEMORIA_VISION_MAX_OUTPUT_TOKENS=800
MEMORIA_OLLAMA_KEEP_ALIVE=5m
MEMORIA_OLLAMA_THINK=false
